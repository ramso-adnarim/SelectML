<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ConnectML Dark Identity -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Brush.Background.Base" Color="#101822"/>
    <SolidColorBrush x:Key="Brush.Surface.Card" Color="#1d2835"/>
    <SolidColorBrush x:Key="Brush.Surface.Popup" Color="#253241"/> 
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border.Base" Color="#2d3b4e"/>
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="#136dec"/>
    
    <!-- Text -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#94a3b8"/>
    <SolidColorBrush x:Key="Brush.Text.Inactive" Color="#64748b"/>
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="#FFFFFF"/>
    
    <!-- Actions / Accent -->
    <SolidColorBrush x:Key="Brush.Action.Primary" Color="#136dec"/>
    <SolidColorBrush x:Key="Brush.Action.Primary.Hover" Color="#3b82f6"/> <!-- Lighter blue -->
    <SolidColorBrush x:Key="Brush.Action.Primary.Foreground" Color="#FFFFFF"/>

    <!-- Danger / Cancel -->
    <SolidColorBrush x:Key="Brush.Cancel.Enable.Border" Color="#FF707070"/>

    <!-- Status -->
    <SolidColorBrush x:Key="Brush.Status.Success" Color="#22c55e"/>
    <SolidColorBrush x:Key="Brush.Status.Warning" Color="#f59e0b"/>
    <SolidColorBrush x:Key="Brush.Status.Error" Color="#ef4444"/>
    <SolidColorBrush x:Key="Brush.Status.Error.Background" Color="#450a0a"/> <!-- Dark Red bg for errors -->
    
    <!-- Inputs -->
    <SolidColorBrush x:Key="Brush.Input.Background" Color="#161f2c"/>
    
    <!-- Legacy Mappings (Temporary Support) -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#101822"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1d2835"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#2d3b4e"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#161f2c"/>
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#450a0a"/>

</ResourceDictionary>
