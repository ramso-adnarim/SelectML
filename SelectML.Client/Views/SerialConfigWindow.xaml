<Window x:Class="SelectML.Client.Views.SerialConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SelectML.Client.Converters"
        Title="Conexão serial" Height="265" Width="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource TextBrush}">
    
    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configuração do Dispositivo" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource TextBrush}"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <!-- Port Selection -->
            <TextBlock Text="Porta COM:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextBrush}"/>
            <ComboBox ItemsSource="{Binding AvailablePorts}" 
                      SelectedItem="{Binding SelectedPort}" 
                      IsEnabled="{Binding IsDisconnected}"
                      Height="30" Margin="0,0,0,15"/>

            <!-- Strategy Selection -->
            <TextBlock Text="Dispositivo (Estratégia):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableStrategies}" 
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedStrategy}" 
                      IsEnabled="{Binding IsDisconnected}"
                      Height="30" Margin="0,0,0,10"/>

            <!-- Custom Config Button -->
            <StackPanel Orientation="Horizontal" Visibility="{Binding IsCustomStrategySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="Editar JSON" 
                        Command="{Binding OpenJsonConfigCommand}" 
                        Padding="10,5" 
                        IsEnabled="{Binding IsDisconnected}"
                        Style="{DynamicResource GhostButton}"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Desconectar" Command="{Binding DisconnectCommand}" 
                    Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,10,0" Style="{DynamicResource DangerButton}"/>
            
            <Button Content="Conectar" Command="{Binding ConnectCommand}" 
                     Visibility="{Binding IsDisconnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,10,0" Style="{DynamicResource PrimaryButton}"/>
            
            <Button Content="Fechar" IsCancel="True" Click="Close_Click" Style="{DynamicResource GhostButton}"/>
        </StackPanel>
    </Grid>
</Window>
