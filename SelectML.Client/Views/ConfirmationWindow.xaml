<Window x:Class="SelectML.Client.Views.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação" Height="200" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Algumas características não foram reconhecidas. Deseja enviar mesmo assim?"
                   TextWrapping="Wrap" VerticalAlignment="Center" FontSize="14"/>

        <CheckBox x:Name="DontAskCheckBox" Grid.Row="1" Content="Não perguntar novamente" Margin="0,10,0,10" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Sim" Width="80" Click="YesButton_Click" IsDefault="True" Margin="0,0,10,0"/>
            <Button Content="Cancelar" Width="80" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
