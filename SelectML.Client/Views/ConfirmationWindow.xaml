<Window x:Class="SelectML.Client.Views.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação" Height="220" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Existem características não reconhecidas no banco de dados. Como deseja prosseguir?"
                   TextWrapping="Wrap" VerticalAlignment="Center" FontSize="14"/>

        <CheckBox x:Name="DontAskCheckBox" Grid.Row="1" Content="Não perguntar novamente (para a opção escolhida)" Margin="0,15,0,15" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Enviar Tudo" Width="90" Click="SendAll_Click" Margin="0,0,10,0" FontWeight="Bold"/>
            <Button Content="Apenas Reconhecidas" Width="140" Click="SendRecognized_Click" Margin="0,0,10,0"/>
            <Button Content="Cancelar" Width="70" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
