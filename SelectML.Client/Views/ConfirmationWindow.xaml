<Window x:Class="SelectML.Client.Views.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação" Height="180" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource TextBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Existem características não reconhecidas na corrida. 
                   Como deseja prosseguir?"
                   TextWrapping="Wrap" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

        <CheckBox x:Name="DontAskCheckBox" Grid.Row="1" Content="Não perguntar novamente" Margin="0,15,0,15" FontSize="12" Foreground="{DynamicResource TextBrush}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Enviar" Width="80" Click="SendAll_Click" Margin="0,0,10,0" Style="{DynamicResource PrimaryButton}"/>
            <Button Content="Apenas reconhecidas" Width="160" Click="SendRecognized_Click" Margin="0,0,10,0" Style="{DynamicResource GhostButton}" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="Cancelar" Width="85" Click="Cancel_Click" IsCancel="True" Style="{DynamicResource DangerButton}"/>
        </StackPanel>
    </Grid>
</Window>
