<Window x:Class="SelectML.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SelectML.Client.ViewModels"
        xmlns:conv="clr-namespace:SelectML.Client.Converters"
        xmlns:sel="clr-namespace:SelectML.Client.Selectors"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="SelectML" Height="650" Width="500"
        Background="{DynamicResource Brush.Background.Base}" 
        Foreground="{DynamicResource Brush.Text.Primary}" 
        Icon="/SelectML-logo-short-light.png"
        FontFamily="Segoe UI, Inter, Sans-Serif">

    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:WidthAdjustmentConverter x:Key="WidthAdjustmentConverter"/>

        <sel:FeatureColumnTemplateSelector x:Key="FeatureColumnTemplateSelector">
            <sel:FeatureColumnTemplateSelector.ReadOnlyTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Characteristic}" 
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </sel:FeatureColumnTemplateSelector.ReadOnlyTemplate>
            <sel:FeatureColumnTemplateSelector.EditableTemplate>
                <DataTemplate>
                    <ComboBox ItemsSource="{Binding DataContext.KnownFeatures, RelativeSource={RelativeSource AncestorType=Window}}" 
                              Text="{Binding Characteristic, UpdateSourceTrigger=PropertyChanged}" 
                              IsEditable="True"
                              IsEnabled="{Binding DataContext.IsPendingAction, RelativeSource={RelativeSource AncestorType=Window}}"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              Height="NaN"
                              VerticalContentAlignment="Center"
                              Padding="4,0,0,0"
                              Margin="0"
                              BorderThickness="0"
                              Background="Transparent">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <!-- Override default Height=30 from global style -->
                                <Setter Property="Height" Value="Auto"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </DataTemplate>
            </sel:FeatureColumnTemplateSelector.EditableTemplate>
        </sel:FeatureColumnTemplateSelector>

        <!-- Helper Style for Labels -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header / Menu -->
            <RowDefinition Height="Auto"/> <!-- Config -->
            <RowDefinition Height="*"/>    <!-- Data Area -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        IconSource="{Binding TrayIconSource}"
                        ToolTipText="{Binding StatusMessage}"
                        DoubleClickCommand="{Binding RestoreFromTrayCommand}" />

        <!-- 1. Header Area -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Menu -->
            <Menu Background="Transparent" VerticalAlignment="Center" IsMainMenu="True">
                <MenuItem Command="{Binding OpenSerialConfigCommand}" 
                          Foreground="{DynamicResource Brush.Text.Primary}" FontWeight="SemiBold">
                    <MenuItem.Header>                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Conexão serial" VerticalAlignment="Center"/>
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource Brush.Status.Success}" Visibility="{Binding IsSerialConnected, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                        Margin="6,0,0,0" VerticalAlignment="Center" x:Name="SerialIndicator"/>
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="SerialIndicator"
                                                                Storyboard.TargetProperty="Opacity"
                                                                From="1.0" To="0.4" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </Menu>

            <!-- Theme Toggle -->
            <Button Grid.Column="1" 
                    Command="{Binding ToggleThemeCommand}" 
                    Style="{StaticResource IconButton}"
                    ToolTip="Alternar tema (Claro/Escuro)" 
                    Width="10" 
                    Height="10" 
                    Cursor="Hand" 
                    BorderBrush="Transparent">
                
                <TextBlock FontSize="6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="☾"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                    <Setter Property="Text" Value="☀"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>
        </Grid>

        <!-- 2. Configurações (Expander) -->
        <Expander Grid.Row="1" IsExpanded="{Binding IsExpanded}" Margin="0,0,0,20">
            <Expander.Header>
                <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Expander}}, Path=ActualWidth, Converter={StaticResource WidthAdjustmentConverter}, FallbackValue=750}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Configuração" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Primary}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0"
                                Visibility="{Binding IsMonitoring, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource Brush.Status.Success}" x:Name="OnlineIndicator"/>
                        <TextBlock Text="Online" Foreground="{DynamicResource Brush.Status.Success}" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                        
                        <!-- Pulse Animation -->
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="OnlineIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1.0" To="0.4" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                    </StackPanel>
                </Grid>
            </Expander.Header>
            
            <!-- Expander Content -->
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Equipamento -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Equipamento" Style="{StaticResource LabelText}"/>
                        <ComboBox ItemsSource="{Binding AvailableParsers}" 
                                  SelectedItem="{Binding SelectedParser}"
                                  IsEnabled="{Binding IsConfigEnabled}"
                                  DisplayMemberPath="MachineName"
                                  Style="{StaticResource {x:Type ComboBox}}"
                                  SelectedIndex="-1"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ClearParserCommand}"
                            Content="✖" Width="25" Height="30" Margin="10,15,0,0"
                            Style="{StaticResource IconButton}" Foreground="{DynamicResource Brush.Status.Error}"
                            IsEnabled="{Binding IsConfigEnabled}"
                            VerticalAlignment="Bottom"/>
                </Grid>

                <!-- Folder & DB -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Folder -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Diretório de monitoramento" Style="{StaticResource LabelText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding WatchDirectory}" IsReadOnly="True" IsEnabled="{Binding IsConfigEnabled}" Style="{StaticResource {x:Type TextBox}}"/>
                            <Button Grid.Column="1" Command="{Binding SelectDirectoryCommand}" Content="..." 
                                    Style="{StaticResource IconButton}" Width="30" Height="30" Margin="5,0,0,0"
                                    Foreground="{DynamicResource Brush.Text.Primary}"
                                    IsEnabled="{Binding IsConfigEnabled}"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Right: DB Config -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Banco de Dados" Style="{StaticResource LabelText}"/>
                        <Border BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel>
                            <TextBlock Text="Servidor" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                <TextBox Text="{Binding DbServer, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsConfigEnabled}" Margin="0,2,0,8" Style="{StaticResource {x:Type TextBox}}"/>
                                
                                <CheckBox Content="Autenticação Windows" 
                                          IsChecked="{Binding DbUseWindowsAuth}" 
                                          IsEnabled="{Binding IsConfigEnabled}" 
                                          Margin="0,0,0,8" 
                                          Foreground="{DynamicResource Brush.Text.Primary}"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Login" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding DbUser, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSqlCredentialsEnabled}" Style="{StaticResource {x:Type TextBox}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Senha" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="DbPasswordBox" IsEnabled="{Binding IsSqlCredentialsEnabled}" Style="{StaticResource {x:Type PasswordBox}}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Text="Base de Dados" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding AvailableDatabases}" 
                                              Text="{Binding DbName}" 
                                              IsEditable="False" 
                                              IsEnabled="{Binding IsConfigEnabled}" 
                                              Style="{StaticResource {x:Type ComboBox}}" VerticalAlignment="Center" Height="28"/>
                                    <Button Grid.Column="1" Command="{Binding LoadDatabasesCommand}" Content="↻" Style="{StaticResource IconButton}" 
                                            Width="20" Margin="5,0,0,0" ToolTip="Atualizar lista" Foreground="{DynamicResource Brush.Text.Primary}" Cursor="Hand" FontSize="15"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Save Button -->
                <Button Grid.Row="2" Command="{Binding SaveConfigCommand}" Content="{Binding ConfigButtonText}"
                        HorizontalAlignment="Left" Width="150" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Expander>

        <!-- 3. Main Data Card -->
        <Border Grid.Row="2" Background="{DynamicResource Brush.Surface.Card}" CornerRadius="6" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Inputs -->
                    <RowDefinition Height="*"/>    <!-- Grid -->
                </Grid.RowDefinitions>

                <!-- Inputs Row -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nome da corrida/lote" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding BatchNumber, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsPendingAction, Converter={StaticResource InverseBooleanConverter}}"
                                 FontSize="16" FontWeight="SemiBold" Height="40" Style="{StaticResource {x:Type TextBox}}"/>
                        <TextBlock Text="{Binding DetectedStationName, StringFormat='Estação: {0}'}" 
                                   FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nome da peça/rotina" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding PartName, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsPendingAction, Converter={StaticResource InverseBooleanConverter}}"
                                 FontSize="16" FontWeight="SemiBold" Height="40">
                             <TextBox.Style>
                                 <Style TargetType="TextBox"> <!-- Not BasedOn to avoid template conflict, using full template -->
                                     <Setter Property="Background" Value="{DynamicResource Brush.Input.Background}"/>
                                     <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                     <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Base}"/>
                                     <Setter Property="BorderThickness" Value="1"/>
                                     <Setter Property="Padding" Value="8,6"/>
                                     <Setter Property="Height" Value="35"/>
                                     <Setter Property="VerticalContentAlignment" Value="Center"/>
                                     <Setter Property="Template">
                                         <Setter.Value>
                                             <ControlTemplate TargetType="{x:Type TextBox}">
                                                 <Border x:Name="border" 
                                                         Background="{TemplateBinding Background}" 
                                                         BorderBrush="{TemplateBinding BorderBrush}" 
                                                         BorderThickness="{TemplateBinding BorderThickness}" 
                                                         CornerRadius="6" 
                                                         SnapsToDevicePixels="True">
                                                     <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                                                 </Border>
                                                 <ControlTemplate.Triggers>
                                                     <Trigger Property="IsEnabled" Value="false">
                                                         <Setter Property="Opacity" TargetName="border" Value="0.5"/>
                                                     </Trigger>
                                                     <Trigger Property="IsMouseOver" Value="true">
                                                         <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource Brush.Text.Secondary}"/>
                                                     </Trigger>
                                                     <Trigger Property="IsKeyboardFocused" Value="true">
                                                         <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource Brush.Border.Focus}"/>
                                                         <Setter Property="BorderThickness" TargetName="border" Value="1"/>
                                                         <Setter Property="Effect" TargetName="border">
                                                             <Setter.Value>
                                                                 <DropShadowEffect Color="{Binding Color, Source={StaticResource Brush.Border.Focus}}" BlurRadius="4" ShadowDepth="0" Opacity="0.4"/>
                                                             </Setter.Value>
                                                         </Setter>
                                                     </Trigger>
                                                     <!-- Validation Trigger (Last to win) -->
                                                     <DataTrigger Binding="{Binding IsPartNameValid}" Value="False">
                                                         <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource Brush.Status.Error}"/>
                                                         <Setter Property="BorderThickness" TargetName="border" Value="2"/>
                                                         <Setter Property="ToolTip" Value="Nome difere do padrão."/>
                                                     </DataTrigger>
                                                 </ControlTemplate.Triggers>
                                             </ControlTemplate>
                                         </Setter.Value>
                                     </Setter>
                                 </Style>
                             </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <DockPanel Grid.Row="1">
                    <TextBlock DockPanel.Dock="Top" Text="Resultados:" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    
                    <DataGrid x:Name="ResultsDataGrid"
                              ItemsSource="{Binding MeasuredResults}" 
                              Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Característica" 
                                                    Width="*" 
                                                    CellTemplateSelector="{StaticResource FeatureColumnTemplateSelector}"/>
                            <DataGridTextColumn Header="Valor" 
                                                Binding="{Binding Value}" 
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Action.Primary}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Warning}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                        
                        <!-- Context Menu for Rows -->
                         <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Excluir valor" 
                                                      Command="{Binding PlacementTarget.Tag.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                         </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </Border>

        <!-- 4. Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0" Cursor="">
            <CheckBox Content="Automático"
                      Foreground="{DynamicResource Brush.Text.Secondary}"
                      IsChecked="{Binding IsAutoMode}" 
                      VerticalAlignment="Center" 
                      Margin="0,0,20,0" 
                      FontWeight="SemiBold"/>
            
            <Button Command="{Binding CancelCommand}" Content="Cancelar" 
                    Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
            
            <Button Command="{Binding SendCommand}" Content="Enviar" 
                    Style="{StaticResource PrimaryButton}"/>
        </StackPanel>

        <!-- 5. Status Bar -->
        <Border Grid.Row="4" Margin="0,10,0,-2" Padding="10,5"
                Background="{DynamicResource Brush.Surface.Card}" 
                BorderBrush="{DynamicResource Brush.Border.Base}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" 
                           Foreground="{DynamicResource Brush.Text.Secondary}" FontWeight="Medium"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentVersion}" VerticalAlignment="Center" 
                               Foreground="{DynamicResource Brush.Text.Inactive}" FontSize="11" Margin="0,0,10,0"/>

                    <!-- Update Notification Button -->
                     <Button Command="{Binding OpenUpdateWindowCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                         <Button.Style>
                             <Style TargetType="Button">
                                 <Setter Property="ToolTip" Value="{Binding CurrentVersion, StringFormat='Versão: {0}'}"/>
                                 <Setter Property="Template">
                                     <Setter.Value>
                                         <ControlTemplate TargetType="Button">
                                              <Viewbox Width="16" Height="16">
                                                  <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Fill="{DynamicResource Brush.Status.Success}"/>
                                              </Viewbox>
                                         </ControlTemplate>
                                     </Setter.Value>
                                 </Setter>
                                 <Style.Triggers>
                                     <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                         <Setter Property="ToolTip" Value="{Binding UpdateMessage}"/>
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Grid>
                                                         <Viewbox Width="16" Height="16">
                                                              <Path Data="M7,20h4c0,1.1-0.9,2-2,2S7,21.1,7,20z M12,2c-5.52,0-10,4.48-10,10c0,5.25,4.08,9.54,9.23,9.96 C11.08,21.61,10.6,21.16,10.22,20.62C6.09,19.98,3,16.4,3,12C3,7.03,7.03,3,12,3s9,4.03,9,9c0,0.48-0.04,0.95-0.12,1.41 c0.87,0.3,1.67,0.76,2.37,1.35C23.82,13.82,24,12.92,24,12C24,6.48,18.62,2,12,2z M12,16l4-4h-2.5V7h-3v5H8L12,16z" Fill="{DynamicResource Brush.Status.Warning}"/>
                                                         </Viewbox>
                                                     </Grid>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                     </DataTrigger>
                                 </Style.Triggers>
                             </Style>
                         </Button.Style>
                     </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    

</Window>
