<Window x:Class="SelectML.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SelectML.Client.ViewModels"
        xmlns:conv="clr-namespace:SelectML.Client.Converters"
        mc:Ignorable="d"
        Title="SelectML - Monitoramento de Medição" Height="600" Width="700"
        Background="#F5F5F5" Icon="/SelectML-logo-short-light.png">

    <!-- Recurso para o Conversor de Cores -->
    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="87*"/>
            <ColumnDefinition Width="248*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Configuração Expansível -->
            <RowDefinition Height="Auto"/>
            <!-- Separador -->
            <RowDefinition Height="*"/>
            <!-- Entradas/Resultados -->
            <RowDefinition Height="Auto"/>
            <!-- Ações Human-in-the-Loop -->
            <RowDefinition Height="Auto"/>
            <!-- Rodapé -->
        </Grid.RowDefinitions>

        <!-- 1. Área de Configuração Expansível -->
        <Expander Grid.Row="0"
                  IsExpanded="{Binding IsExpanded}"
                  BorderBrush="#DDDDDD" BorderThickness="1" Background="White" Padding="10" Grid.ColumnSpan="2">
            <Expander.Header>
                <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Expander}}, Path=ActualWidth, Converter={conv:WidthAdjustmentConverter}, FallbackValue=650}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Configuração do Monitoramento" FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0"
                                Visibility="{Binding IsMonitoring, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Ellipse Width="10" Height="10" Fill="Green" x:Name="OnlineIndicator"/>
                        <TextBlock Text="Online" Foreground="Green" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>

                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="OnlineIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1.0" To="0.4" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                    </StackPanel>
                </Grid>
            </Expander.Header>
            <Grid Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Seleção de Máquina (Plugin) -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Configuração da Máquina (Plugin):" FontWeight="SemiBold" Foreground="#333"/>
                    <ComboBox ItemsSource="{Binding AvailableParsers}" 
                              SelectedItem="{Binding SelectedParser}"
                              IsEnabled="{Binding IsConfigEnabled}"
                              DisplayMemberPath="MachineName"
                              Height="30" Margin="0,5,0,0"
                              SelectedIndex="0"/>
                </StackPanel>

                <!-- Seleção de Pasta -->
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock Text="Diretório de Monitoramento:" FontWeight="SemiBold" Foreground="#333"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding WatchDirectory}" IsReadOnly="True" 
                                 IsEnabled="{Binding IsConfigEnabled}"
                                 VerticalContentAlignment="Center" Height="30"/>
                        <Button Grid.Column="1" Command="{Binding SelectDirectoryCommand}" 
                                IsEnabled="{Binding IsConfigEnabled}"
                                Content="..." Width="40" Margin="5,0,0,0"/>
                    </Grid>

                    <!-- Configuração SQL Database -->
                    <TextBlock Text="Configuração Banco de Dados:" FontWeight="SemiBold" Foreground="#333" Margin="0,10,0,5"/>
                    <Border BorderBrush="#EEEEEE" BorderThickness="1" Padding="10" Background="#FAFAFA">
                        <StackPanel>
                            <!-- Servidor -->
                            <TextBlock Text="Servidor:" FontSize="11" Foreground="#666"/>
                            <TextBox Text="{Binding DbServer, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsConfigEnabled}"
                                     Height="25" Margin="0,2,0,5"/>

                            <!-- Autenticação Windows -->
                            <CheckBox Content="Autenticação Windows"
                                      IsChecked="{Binding DbUseWindowsAuth}"
                                      IsEnabled="{Binding IsConfigEnabled}"
                                      Margin="0,5,0,5"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Login -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Login:" FontSize="11" Foreground="#666"/>
                                    <TextBox Text="{Binding DbUser, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsSqlCredentialsEnabled}"
                                             Height="25" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Senha -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Senha:" FontSize="11" Foreground="#666"/>
                                    <PasswordBox x:Name="DbPasswordBox"
                                                 IsEnabled="{Binding IsSqlCredentialsEnabled}"
                                                 PasswordChar="*"
                                                 Height="25" Margin="0,2,0,0"
                                                 PasswordChanged="DbPasswordBox_PasswordChanged"/>
                                </StackPanel>
                            </Grid>

                            <!-- Base de Dados (Initial Catalog) -->
                            <TextBlock Text="Base de Dados (Initial Catalog):" FontSize="11" Foreground="#666" Margin="0,5,0,0"/>
                            <Grid Margin="0,2,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox ItemsSource="{Binding AvailableDatabases}"
                                          Text="{Binding DbName}"
                                          IsEditable="True"
                                          IsEnabled="{Binding IsConfigEnabled}"
                                          Height="25"/>

                                <Button Grid.Column="1" Command="{Binding LoadDatabasesCommand}"
                                        Content="↻"
                                        ToolTip="Listar Bancos de Dados"
                                        IsEnabled="{Binding IsConfigEnabled}"
                                        Margin="5,0,0,0" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Botão Salvar/Editar -->
                <Button Grid.Row="2" 
                        Command="{Binding SaveConfigCommand}"
                        Content="{Binding ConfigButtonText}"
                        Height="35" Width="150" HorizontalAlignment="Left"
                        Background="{Binding IsConfigLocked, Converter={StaticResource BooleanToBrushConverter}}" 
                        FontWeight="Bold"
                        Foreground="White"/>
            </Grid>
        </Expander>

        <!-- 2. Área de Dados (Entradas Manuais e Resultados) -->
        <Grid Grid.Row="2" Margin="0,15,0,0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Entradas Manuais (Visualização) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CÓDIGO DA CORRIDA/LOTE:" Foreground="#555" FontSize="11" FontWeight="Bold"/>
                        <TextBox Text="{Binding BatchNumber, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsPendingAction, Converter={StaticResource InverseBooleanConverter}}"
                                 Background="#FAFAFA" Height="30" FontSize="14" Margin="0,2,0,0" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CÓDIGO DA PEÇA:" Foreground="#555" FontSize="11" FontWeight="Bold"/>
                        <TextBox Text="{Binding PartName, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsPendingAction, Converter={StaticResource InverseBooleanConverter}}"
                                 Background="#FAFAFA" Height="30" FontSize="14" Margin="0,2,0,0" Padding="5"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Tabela de Resultados -->
            <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" Text="RESULTADOS DETECTADOS:" FontWeight="Bold" Margin="0,0,0,5"/>
                <DataGrid ItemsSource="{Binding MeasuredResults}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Característica" Binding="{Binding Characteristic}" Width="*"/>
                        <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="120" FontWeight="Bold" Foreground="#007ACC"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- 3. Ações Human-in-the-Loop -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Grid.ColumnSpan="2">
            <Button Command="{Binding CancelCommand}" Content="Cancelar"
                    Width="100" Height="35" Margin="0,0,10,0" Background="#D9534F" Foreground="White" FontWeight="Bold"/>
            <Button Command="{Binding SendCommand}" Content="Enviar"
                    Width="100" Height="35" Background="#5CB85C" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- 4. Rodapé -->
        <StatusBar Grid.Row="4" Margin="0,10,0,0" Background="#EFEFEF" Height="30" Grid.ColumnSpan="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" Foreground="#333"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>