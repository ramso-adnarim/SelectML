<Window x:Class="SelectML.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SelectML.Client.ViewModels"
        xmlns:conv="clr-namespace:SelectML.Client.Converters"
        xmlns:sel="clr-namespace:SelectML.Client.Selectors"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="SelectML - Monitoramento de Medição" Height="600" Width="700"
        Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource TextBrush}" Icon="/SelectML-logo-short-light.png">

    <!-- Recurso para o Conversor de Cores -->
    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:WidthAdjustmentConverter x:Key="WidthAdjustmentConverter"/>

        <sel:FeatureColumnTemplateSelector x:Key="FeatureColumnTemplateSelector">
            <sel:FeatureColumnTemplateSelector.ReadOnlyTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Characteristic}" VerticalAlignment="Center" Margin="5,0"/>
                </DataTemplate>
            </sel:FeatureColumnTemplateSelector.ReadOnlyTemplate>
            <sel:FeatureColumnTemplateSelector.EditableTemplate>
                <DataTemplate>
                    <ComboBox ItemsSource="{Binding DataContext.KnownFeatures, RelativeSource={RelativeSource AncestorType=Window}}" 
                              Text="{Binding Characteristic, UpdateSourceTrigger=PropertyChanged}" 
                              IsEditable="True"
                              IsEnabled="{Binding DataContext.IsPendingAction, RelativeSource={RelativeSource AncestorType=Window}}"
                              Margin="2"/>
                </DataTemplate>
            </sel:FeatureColumnTemplateSelector.EditableTemplate>
        </sel:FeatureColumnTemplateSelector>
    </Window.Resources>

    <Grid Margin="15,5,15,15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="87*"/>
            <ColumnDefinition Width="248*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toggle Theme Button -->
            <RowDefinition Height="Auto"/>
            <!-- Configuração Expansível -->
            <RowDefinition Height="Auto"/>
            <!-- Separador -->
            <RowDefinition Height="*"/>
            <!-- Entradas/Resultados -->
            <RowDefinition Height="Auto"/>
            <!-- Ações Human-in-the-Loop -->
            <RowDefinition Height="Auto"/>
            <!-- Rodapé -->
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        IconSource="{Binding TrayIconSource}"
                        ToolTipText="{Binding StatusMessage}"
                        DoubleClickCommand="{Binding RestoreFromTrayCommand}" />

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="Transparent" VerticalAlignment="Center" IsMainMenu="True">
            <MenuItem Header="Conexão serial" Foreground="{DynamicResource TextBrush}" Command="{Binding OpenSerialConfigCommand}"/>
                <!-- <MenuItem Header="Configurar Conexão..." Command="{Binding OpenSerialConfigCommand}"/>-->
        </Menu>

        <!-- Theme Toggle Button -->
        <Button Grid.Row="0" Command="{Binding ToggleThemeCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,0,0" Grid.ColumnSpan="2"
                Width="15" Height="15" Background="Transparent" BorderThickness="0" ToolTip="Alternar modo (claro/escuro)">
             <TextBlock FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                 <TextBlock.Style>
                     <Style TargetType="TextBlock">
                         <Setter Property="Text" Value="☾"/>
                         <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                         <Style.Triggers>
                             <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                 <Setter Property="Text" Value="☀"/>
                                 <Setter Property="Foreground" Value="White"/>
                             </DataTrigger>
                         </Style.Triggers>
                     </Style>
                 </TextBlock.Style>
             </TextBlock>
        </Button>

        <!-- 1. Área de Configuração Expansível -->
        <Expander Grid.Row="1"
                  IsExpanded="{Binding IsExpanded}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" Padding="5" Grid.ColumnSpan="2">
            <Expander.Header>
                <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Expander}}, Path=ActualWidth, Converter={StaticResource WidthAdjustmentConverter}, FallbackValue=650}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Configuração" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0"
                                Visibility="{Binding IsMonitoring, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Ellipse Width="10" Height="10" Fill="Green" x:Name="OnlineIndicator"/>
                        <TextBlock Text="Online" Foreground="Green" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>

                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="OnlineIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1.0" To="0.4" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                    </StackPanel>
                </Grid>
            </Expander.Header>
            <Grid Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Seleção de Máquina (Plugin) -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Equipamento:" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding AvailableParsers}" 
                                  SelectedItem="{Binding SelectedParser}"
                                  IsEnabled="{Binding IsConfigEnabled}"
                                  DisplayMemberPath="MachineName"
                                  Height="24"
                                  SelectedIndex="-1"/>
                        <Button Grid.Column="1" Content="✖" 
                                Command="{Binding ClearParserCommand}"
                                ToolTip="Desselecionar (Modo Apenas Serial)"
                                Width="24" Height="24" Margin="5,0,0,0"
                                IsEnabled="{Binding IsConfigEnabled}"
                                Foreground="Red" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>

                <!-- Seleção de Pasta -->
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock Text="Diretório de monitoramento:" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding WatchDirectory}" IsReadOnly="True" 
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            CaretBrush="{DynamicResource TextBrush}"
                            IsEnabled="{Binding IsConfigEnabled}"
                            VerticalContentAlignment="Center" Height="25"/>
                        <Button Grid.Column="1" Command="{Binding SelectDirectoryCommand}" 
                                IsEnabled="{Binding IsConfigEnabled}"
                                Content="..." Width="40" Margin="5,0,0,0"/>
                    </Grid>

                    <!-- Configuração SQL Database -->
                    <TextBlock Text="Banco de dados:" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="10" Background="{DynamicResource InputBackgroundBrush}">
                        <StackPanel>
                            <!-- Servidor -->
                            <TextBlock Text="Servidor:" FontSize="11" 
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBox Text="{Binding DbServer, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsConfigEnabled}"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     Height="20" Margin="0,2,0,5"/>

                            <!-- Autenticação Windows -->
                            <CheckBox Content="Autenticação Windows"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding DbUseWindowsAuth}"
                                      IsEnabled="{Binding IsConfigEnabled}"
                                      Margin="0,5,0,5"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Login -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Login:" FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBox Text="{Binding DbUser, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsSqlCredentialsEnabled}"
                                             Background="{DynamicResource InputBackgroundBrush}"
                                             Foreground="{DynamicResource TextBrush}"
                                             CaretBrush="{DynamicResource TextBrush}"
                                             Height="20" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Senha -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Senha:" FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                    <PasswordBox x:Name="DbPasswordBox"
                                                 IsEnabled="{Binding IsSqlCredentialsEnabled}"
                                                 Background="{DynamicResource InputBackgroundBrush}"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 CaretBrush="{DynamicResource TextBrush}"
                                                 PasswordChar="*"
                                                 Height="20" Margin="0,2,0,0"
                                                 PasswordChanged="DbPasswordBox_PasswordChanged"/>
                                </StackPanel>
                            </Grid>

                            <!-- Base de Dados (Initial Catalog) -->
                            <TextBlock Text="Base de dados:" 
                                       FontSize="11"                                        
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,5,0,0"/>
                            <Grid Margin="0,2,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox ItemsSource="{Binding AvailableDatabases}"
                                          Text="{Binding DbName}"
                                          Background="{DynamicResource InputBackgroundBrush}"
                                          IsEditable="True"
                                          IsEnabled="{Binding IsConfigEnabled}"
                                          Height="25"/>

                                <Button Grid.Column="1" Command="{Binding LoadDatabasesCommand}"
                                        Content="↻"
                                        ToolTip="Listar base de dados"
                                        IsEnabled="{Binding IsConfigEnabled}"
                                        Margin="5,0,0,0" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Botão Salvar/Editar -->
                <Button Grid.Row="2" 
                        Command="{Binding SaveConfigCommand}"
                        Content="{Binding ConfigButtonText}"
                        Height="30" Width="110" HorizontalAlignment="Left"
                        Background="{Binding IsConfigLocked, Converter={StaticResource BooleanToBrushConverter}}" 
                        FontWeight="Bold"
                        Foreground="White"/>
            </Grid>
        </Expander>

        <!-- 2. Área de Dados (Entradas Manuais e Resultados) -->
        <Grid Grid.Row="3" Margin="0,15,0,0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Entradas Manuais (Visualização) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nome da corrida/lote:" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="Bold"/>
                        <TextBox Text="{Binding BatchNumber, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsPendingAction, Converter={StaticResource InverseBooleanConverter}}"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 Height="30" FontSize="14" Margin="0,2,0,0" Padding="5"/>
                         <!-- Feedback Estação Detectada -->
                         <TextBlock Text="{Binding DetectedStationName, StringFormat='Estação Detectada: {0}'}"
                                    FontSize="10" Foreground="{DynamicResource TextBrush}" Opacity="0.7" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nome da rotina:" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="Bold"/>
                        <TextBox Text="{Binding PartName, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsPendingAction, Converter={StaticResource InverseBooleanConverter}}"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 Height="30" FontSize="14" Margin="0,2,0,0" Padding="5">
                             <TextBox.Style>
                                 <Style TargetType="TextBox">
                                     <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                     <Setter Property="BorderThickness" Value="1"/>
                                     <Style.Triggers>
                                         <DataTrigger Binding="{Binding IsPartNameValid}" Value="False">
                                             <Setter Property="BorderBrush" Value="Red"/>
                                             <Setter Property="BorderThickness" Value="2"/>
                                             <Setter Property="ToolTip" Value="Nome da peça difere do padrão cadastrado para este lote."/>
                                         </DataTrigger>
                                     </Style.Triggers>
                                 </Style>
                             </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Tabela de Resultados -->
            <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" Text="Resultados:" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource TextBrush}"/>
                <DataGrid ItemsSource="{Binding MeasuredResults}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          Background="{DynamicResource CardBackgroundBrush}"
                          AlternationCount="2">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <!-- RowStyle para indicar itens não reconhecidos -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <!-- Pass MainViewModel to Row Tag for ContextMenu access -->
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Excluir Valor" 
                                                  Command="{Binding PlacementTarget.Tag.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsRecognized}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource WarningBackgroundBrush}"/>
                                    <Setter Property="ToolTip" Value="Característica não encontrada no banco"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header=" Característica" Width="*" CellTemplateSelector="{StaticResource FeatureColumnTemplateSelector}"/>
                        <DataGridTextColumn Header=" Valor" Binding="{Binding Value}" Width="*" FontWeight="Bold">
                             <DataGridTextColumn.ElementStyle>
                                 <Style TargetType="TextBlock">
                                     <Setter Property="Foreground" Value="#007ACC"/>
                                 </Style>
                             </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- 3. Ações Human-in-the-Loop -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Grid.ColumnSpan="2">
            <CheckBox Content="Automático"
                      IsChecked="{Binding IsAutoMode}"
                      VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
            <Button Command="{Binding CancelCommand}" Content="Cancelar"
                    Width="80" Height="25" Margin="0,0,10,0" Background="#FFB70303" Foreground="White" FontWeight="Bold"/>
            <Button Command="{Binding SendCommand}" Content="Enviar"
                    Width="80" Height="25" Background="#5CB85C" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- 4. Rodapé -->
        <StatusBar Grid.Row="5" Margin="0,10,0,0" Background="{DynamicResource CardBackgroundBrush}" Height="30" Grid.ColumnSpan="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
            </StatusBarItem>

            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                     <!-- Version Text -->
                     <TextBlock Text="{Binding CurrentVersion}" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="Gray" FontSize="10"/>

                     <!-- Update Icon -->
                     <Button Command="{Binding OpenUpdateWindowCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                         <Button.Style>
                             <Style TargetType="Button">
                                 <!-- Default State (No Update) -->
                                 <Setter Property="ToolTip" Value="{Binding CurrentVersion, StringFormat='Versão Atual: {0}'}"/>
                                 <Setter Property="Template">
                                     <Setter.Value>
                                         <ControlTemplate TargetType="Button">
                                              <!-- Simple Circle Check -->
                                              <Viewbox Width="16" Height="16">
                                                  <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Fill="Gray"/>
                                              </Viewbox>
                                         </ControlTemplate>
                                     </Setter.Value>
                                 </Setter>

                                 <!-- Update Available State -->
                                 <Style.Triggers>
                                     <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                         <Setter Property="ToolTip" Value="{Binding UpdateMessage}"/>
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Grid>
                                                         <!-- Pulsing Animation -->
                                                          <Grid.Triggers>
                                                              <EventTrigger RoutedEvent="Loaded">
                                                                  <BeginStoryboard>
                                                                      <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                          <DoubleAnimation Storyboard.TargetName="ScaleTrans"
                                                                                           Storyboard.TargetProperty="ScaleX"
                                                                                           From="1.0" To="1.2" Duration="0:0:0.5"/>
                                                                          <DoubleAnimation Storyboard.TargetName="ScaleTrans"
                                                                                           Storyboard.TargetProperty="ScaleY"
                                                                                           From="1.0" To="1.2" Duration="0:0:0.5"/>
                                                                      </Storyboard>
                                                                  </BeginStoryboard>
                                                              </EventTrigger>
                                                          </Grid.Triggers>

                                                          <!-- Up Arrow Icon -->
                                                          <Viewbox Width="16" Height="16" RenderTransformOrigin="0.5,0.5">
                                                              <Viewbox.RenderTransform>
                                                                  <ScaleTransform x:Name="ScaleTrans"/>
                                                              </Viewbox.RenderTransform>
                                                              <Path Data="M7,20h4c0,1.1-0.9,2-2,2S7,21.1,7,20z M12,2c-5.52,0-10,4.48-10,10c0,5.25,4.08,9.54,9.23,9.96 C11.08,21.61,10.6,21.16,10.22,20.62C6.09,19.98,3,16.4,3,12C3,7.03,7.03,3,12,3s9,4.03,9,9c0,0.48-0.04,0.95-0.12,1.41 c0.87,0.3,1.67,0.76,2.37,1.35C23.82,13.82,24,12.92,24,12C24,6.48,18.62,2,12,2z M12,16l4-4h-2.5V7h-3v5H8L12,16z" Fill="#FFD700"/>
                                                          </Viewbox>
                                                     </Grid>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                     </DataTrigger>
                                 </Style.Triggers>
                             </Style>
                         </Button.Style>
                     </Button>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
