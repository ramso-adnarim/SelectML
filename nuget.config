<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Limpa fontes herdadas para evitar conflitos -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- Mapeia TODOS os pacotes (*) para serem baixados do nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>